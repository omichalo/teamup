# ============================================
# TeamUp - Variables d'environnement
# ============================================
# 
# Ce fichier liste toutes les variables d'environnement nécessaires pour le projet.
# Copiez ce fichier vers .env.local et remplissez les valeurs.
# 
# IMPORTANT: Ne jamais commiter .env.local dans Git !
# ============================================

# ============================================
# Configuration Firebase (publiques)
# ============================================
# Ces variables sont publiques par design (préfixe NEXT_PUBLIC_)
# Elles sont sécurisées par des restrictions de domaine dans Firebase Console
# Les valeurs par défaut sont définies dans next.config.ts et apphosting.yaml

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# URL de l'application (publique)
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# ============================================
# Configuration Firebase (privées, serveur uniquement)
# ============================================
# Ces variables sont utilisées uniquement côté serveur

# Option 1: Utiliser un fichier service account (recommandé pour le développement local)
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# Option 2: Utiliser des variables d'environnement (alternative)
# FB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FB_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FB_PROJECT_ID=your-project-id

# Ancien format (toujours supporté)
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ============================================
# Configuration Discord (privées, serveur uniquement)
# ============================================

# Token du bot Discord (obligatoire pour les interactions Discord)
DISCORD_TOKEN=your_discord_bot_token

# Clé publique du bot Discord (obligatoire pour valider les interactions)
DISCORD_PUBLIC_KEY=your_discord_public_key

# ID de l'application Discord
DISCORD_APPLICATION_ID=your_discord_application_id

# ID du serveur Discord
DISCORD_SERVER_ID=your_discord_server_id

# ID du canal Discord pour les liens de licence (optionnel)
DISCORD_LICENSE_CHANNEL_ID=your_discord_channel_id

# Secret partagé pour l'authentification des webhooks Discord (optionnel)
DISCORD_WEBHOOK_SECRET=your_discord_webhook_secret

# ============================================
# Configuration FFTT API (privées, serveur uniquement)
# ============================================

# Identifiants FFTT pour l'API officielle
ID_FFTT=your_fftt_id
PWD_FFTT=your_fftt_password

# Code du club FFTT (optionnel, valeur par défaut: 08781477)
# Note: Ce n'est PAS un secret, c'est le code public du club
CLUB_CODE=08781477

# ============================================
# Configuration SMTP (privées, serveur uniquement)
# ============================================
# Pour l'envoi d'emails (vérification, réinitialisation de mot de passe)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
SMTP_SECURE=false

# ============================================
# Protection CSRF (privée, serveur uniquement)
# ============================================
# Secret utilisé pour générer et valider les tokens CSRF
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"

CSRF_SECRET=your_csrf_secret_min_32_chars_recommended_64_chars

# ============================================
# Configuration de l'application (serveur uniquement)
# ============================================

# URL de l'application pour les routes API (serveur uniquement)
# Utilisé pour la validation CSRF et la génération de liens
APP_URL=https://your-app-domain.com

# Mode debug (pour activer les logs de debug en production)
# À désactiver en production pour éviter les logs verbeux
DEBUG=false

# ============================================
# Notes importantes
# ============================================
# 
# 1. Variables NEXT_PUBLIC_* : 
#    - Sont incluses dans le bundle JavaScript côté client
#    - Sont publiques par design (sécurisées par Firebase)
#    - Ne jamais y mettre de secrets
#
# 2. Variables sans préfixe NEXT_PUBLIC_ :
#    - Accessibles uniquement côté serveur
#    - Ne jamais les exposer au client
#
# 3. En production (Firebase App Hosting) :
#    - Les secrets sont gérés via Firebase Secret Manager
#    - Voir apphosting.yaml pour la configuration
#    - Utiliser: firebase apphosting:secrets:set SECRET_NAME
#
# 4. Pour plus d'informations :
#    - Voir docs/SECURITY.md pour la gestion des secrets
#    - Voir docs/SETUP_DEV_FIREBASE.md pour la configuration Firebase
#    - Voir docs/DISCORD.md pour la configuration Discord
