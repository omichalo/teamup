# Secrets spécifiques à l'environnement staging App Hosting (sqyping-teamup-dev).
# Copier vers .env.staging (gitignored) — ne pas committer.
#
# Le webhook local (stripe listen) reste dans .env.local avec un whsec_ différent.

# Signing secret du webhook Stripe Dashboard (URL staging)
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_staging
